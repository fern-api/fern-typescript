    _getParsedProperties: async () => (await getMemoizedSchema(getter))._getParsedProperties(),
  };

  return {
    ...baseSchema,
    ...getSchemaUtils(baseSchema),
    ...getObjectLikeUtils(baseSchema),
    ...getObjectUtils(baseSchema),
  };
