        "contents": Array [
          Object {
            "contents": "import { SchemaUtils } from \\"./builders\\";

export type Schema<Raw = unknown, Parsed = unknown> = BaseSchema<Raw, Parsed> & SchemaUtils<Raw, Parsed>;

export type inferRaw<S extends Schema> = S extends Schema<infer Raw, any> ? Raw : never;
export type inferParsed<S extends Schema> = S extends Schema<any, infer Parsed> ? Parsed : never;

export interface BaseSchema<Raw, Parsed> {
    parse: (raw: Raw, opts?: SchemaOptions) => Parsed;
    json: (paresd: Parsed, opts?: SchemaOptions) => Raw;
}

export interface SchemaOptions {
    /**
     * @default false
     */
    skipUnknownKeysOnParse?: boolean;

    /**
     * @default false
     */
    includeUnknownKeysOnJson?: boolean;
}
",
            "name": "Schema.ts",
            "type": "file",
          },
          Object {
            "contents": Array [
              Object {
                "contents": "import { boolean, discriminant, list, number, object, string, stringLiteral, union } from \\"../builders\\";
import { property } from \\"../builders/object/property\\";
import { itSchema } from \\"./utils/itSchema\\";

describe(\\"Schema\\", () => {
    itSchema(
        \\"large nested object\\",
        object({
            a: string(),
            b: stringLiteral(\\"b value\\"),
            c: property(
                \\"raw_c\\",
                list(
                    object({
                        animal: union(discriminant(\\"type\\", \\"_type\\"), {
                            dog: { value: boolean() },
                            cat: { value: property(\\"raw_cat\\", number()) },
                        }),
                    })
                )
            ),
            d: property(\\"raw_d\\", boolean()),
        }),
        {
            raw: {
                a: \\"hello\\",
                b: \\"b value\\",
                raw_c: [
                    {
                        animal: {
                            _type: \\"dog\\",
                            value: true,
                        },
                    },
                    {
                        animal: {
                            _type: \\"cat\\",
                            raw_cat: 42,
                        },
                    },
                ],
                raw_d: false,
            },
            parsed: {
                a: \\"hello\\",
                b: \\"b value\\",
                c: [
                    {
